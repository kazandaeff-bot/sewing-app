generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Employee {
  id        String   @id @default(cuid())
  name      String
  code      String   @unique
  username  String   @unique
  password  String
  role      String   @default("sewer") // sewer | qc | supervisor | seller | technologist | cutter | ironing | customer
  customerId String?
  customer   Customer? @relation(fields: [customerId], references: [id])
  tasks        Task[]
  sewingTasks  SewingTask[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Product {
  id             String          @id @default(cuid())
  name           String
  article        String          @unique
  imageUrl       String?
  sewerRate      Float           @default(150)
  homeRate       Float           @default(0)   // Ставка для надомниц (0 = не задана, используется sewerRate)
  qcRate         Float           @default(50)
  ironingRate    Float           @default(10)  // Ставка за утюжку
  cuttingRate    Float           @default(30)  // Ставка за раскрой
  reworkRate     Float           @default(80)
  reworkPaid     Boolean         @default(true) // Оплачивается ли переделка
  isKit          Boolean         @default(false) // Комплект (напр. ч/б)
  kitComboColors  String?         // JSON: {"ч/б":["чёрный","белый"]} — расшифровка комплекта
  reworkReasons    ReworkReason[]
  sizes            ProductSize[]
  colors           ProductColor[]
  tasks            Task[]
  planItems        PlanItem[]
  cuttingPlanItems CuttingPlanItem[]
  sewingTaskItems  SewingTaskItem[]
  sellerPlanItems  SellerPlanItem[]
  boxItems         BoxItem[]
  boxCapacities    BoxCapacity[]
  customerProducts CustomerProduct[]
  materialNorms   MaterialNorm[]
  cuttingLeftovers CuttingLeftover[]
  sizeRates        ProductSizeRate[]
  invoiceItems     InvoiceItem[]
  updItems         UPDItem[]
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
}

model ProductSize {
  id        String  @id @default(cuid())
  productId String
  size      String
  order     Int     @default(0)
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([productId, size])
}

// Нормы ставок по размерам (P2)
model ProductSizeRate {
  id          String  @id @default(cuid())
  productId   String
  size        String
  sewerRate   Float?  // NULL = использовать базовую ставку изделия
  homeRate    Float?
  qcRate      Float?
  ironingRate Float?
  cuttingRate Float?
  fabricCoeff Float?  // Коэффициент расхода ткани относительно базовой нормы (напр. S=0.9, M=1.0, L=1.1)
  product     Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, size])
}

model ProductColor {
  id        String  @id @default(cuid())
  productId String
  color     String
  colorHex  String  @default("#9ca3af")
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([productId, color])
}

model ReworkReason {
  id        String   @id @default(cuid())
  productId String
  text      String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model Task {
  id              String           @id @default(cuid())
  employeeId      String
  productId       String
  size            String
  color           String
  colorHex        String           @default("#9ca3af")
  quantity        Int
  status          String           @default("new")
  actualQuantity  Int?
  fabricDefect    Int              @default(0)
  defectNote      String?
  completedAt     DateTime?
  employee        Employee         @relation(fields: [employeeId], references: [id])
  product         Product          @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
}

// Переделки для SewingTaskItem (новая модель)
model SewingRework {
  id               String           @id @default(cuid())
  sewingTaskItemId String           // Ссылка на SewingTaskItem
  sewingTaskId     String           // Ссылка на SewingTask (для удобства)
  quantity         Int
  reason           String
  status           String           @default("pending") // pending | in_progress | pending_qc | completed
  sewingTaskItem   SewingTaskItem   @relation(fields: [sewingTaskItemId], references: [id])
  sewingTask       SewingTask       @relation(fields: [sewingTaskId], references: [id])
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
}

// ============ СПРАВОЧНИК: Города ============
model City {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
}

// ============ СПРАВОЧНИК: Типы коробов ============
model BoxType {
  id          String         @id @default(cuid())
  name        String         // напр. "Стандартный", "Большой"
  dimensions  String?        // напр. "60x40x40 см"
  capacities  BoxCapacity[]
  boxes       Box[]
  createdAt   DateTime       @default(now())
}

model BoxCapacity {
  id         String   @id @default(cuid())
  boxTypeId  String
  productId  String
  size       String   // Размер изделия
  maxQty     Int      // Макс. кол-во данного изделия данного размера в этом коробе
  boxType    BoxType  @relation(fields: [boxTypeId], references: [id], onDelete: Cascade)
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@unique([boxTypeId, productId, size])
}

// ============ СПРАВОЧНИК: Заказчики ============
model Customer {
  id                  String           @id @default(cuid())
  name                String           @unique
  type                String           @default("organization") // organization | ip | individual
  inn                 String?
  kpp                 String?
  legalAddress        String?
  postalAddress       String?
  phone               String?
  email               String?
  // Банковские реквизиты
  bankName            String?
  bik                 String?
  checkingAccount     String?          // Расчётный счёт
  corrAccount         String?          // Корреспондентский счёт
  bankCity            String?          // Город банка
  // Старые поля (оставлены для совместимости)
  contactInfo         String?
  showMaterialBalance Boolean          @default(false)
  employees           Employee[]
  customerProducts    CustomerProduct[]
  plans               Plan[]
  sellerPlans         SellerPlan[]
  invoices            Invoice[]
  upds                UPD[]
  deals               Deal[]
  contracts           Contract[]
  materials           Material[]
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt
}

model CustomerProduct {
  id              String    @id @default(cuid())
  customerId      String
  productId       String
  customBoxCapacity Int?
  customWeight    Float?
  customDimensions String?
  customWidth     Float?
  customHeight    Float?
  customer        Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  product         Product   @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([customerId, productId])
}

// ============ МОДУЛЬ 1: План пошива ============
model Plan {
  id           String        @id @default(cuid())
  name         String
  status       String        @default("draft") // draft | approved | in_work | shipped | shipped_paid
  priority     String        @default("normal") // urgent | normal | low
  deadline     DateTime?     // Дедлайн плана
  customerId   String?
  customer     Customer?     @relation(fields: [customerId], references: [id])
  items        PlanItem[]
  cuttingPlans CuttingPlan[] // Один план может иметь несколько раскроев (основной + дополнительные)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model PlanItem {
  id       String  @id @default(cuid())
  planId   String
  productId String
  size     String
  color    String
  colorHex String  @default("#9ca3af")
  quantity Int
  plan     Plan    @relation(fields: [planId], references: [id], onDelete: Cascade)
  product  Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

// ============ МОДУЛЬ 2: План раскроя ============
model CuttingPlan {
  id           String           @id @default(cuid())
  planId       String           // Не уникально — план может иметь несколько раскроев
  label        String?          // "Основной", "Дополнение 1" и т.д.
  status       String           @default("in_work") // in_work | cut
  items        CuttingPlanItem[]
  sewingTasks  SewingTask[]
  leftovers    CuttingLeftover[]
  plan         Plan             @relation(fields: [planId], references: [id])
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
}

model CuttingPlanItem {
  id             String        @id @default(cuid())
  cuttingPlanId  String
  productId      String
  size           String
  color          String
  colorHex       String        @default("#9ca3af")
  plannedQty     Int
  actualQty      Int?
  bundleCount    Int?          // Кол-во пачек (настилов) — вычисляемое: кол-во заходов
  cuttingPlan    CuttingPlan   @relation(fields: [cuttingPlanId], references: [id], onDelete: Cascade)
  product        Product       @relation(fields: [productId], references: [id], onDelete: Cascade)
  passes         CuttingPass[]
}

// Заход раскроя (настил) — один проход раскладки и резки
model CuttingPass {
  id                 String           @id @default(cuid())
  cuttingPlanItemId  String
  passNumber         Int              // Номер захода (1, 2, 3...)
  layers             Int              // Кол-во слоёв настила в этом заходе
  actualQty          Int?             // Сколько изделий получено из этого захода (обычно = layers, но может отличаться при браке)
  note               String?          // Примечание (напр. "ткань кончилась", "брак ткани")
  cuttingPlanItem    CuttingPlanItem  @relation(fields: [cuttingPlanItemId], references: [id], onDelete: Cascade)
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  @@unique([cuttingPlanItemId, passNumber])
}

// ============ Остатки кроя ============
model CuttingLeftover {
  id             String   @id @default(cuid())
  cuttingPlanId  String
  cuttingPlanItemId String?
  productId      String
  size           String
  color          String
  colorHex       String   @default("#9ca3af")
  quantity       Int             // Всего лишних единиц кроя
  sewnQty        Int      @default(0) // Сколько уже пошито из остатка
  status         String   @default("free") // free | assigned | partially_sewn | fully_sewn
  source         String   @default("cutting") // cutting — из раскроя, manual — добавлено вручную
  note           String?         // Комментарий (напр. "зарисовка на пустом участке")
  cuttingPlan    CuttingPlan @relation(fields: [cuttingPlanId], references: [id])
  product        Product  @relation(fields: [productId], references: [id])
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

// ============ МОДУЛЬ 3: Задания для швей ============
model SewingTask {
  id              String           @id @default(cuid())
  cuttingPlanId   String
  employeeId      String
  status          String           @default("issued") // issued | in_work | pending_ironing | pending_qc | completed
  items           SewingTaskItem[]
  reworks         SewingRework[]
  cuttingPlan     CuttingPlan      @relation(fields: [cuttingPlanId], references: [id])
  employee        Employee         @relation(fields: [employeeId], references: [id])
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
}

model SewingTaskItem {
  id              String      @id @default(cuid())
  sewingTaskId    String
  productId       String
  size            String
  color           String
  colorHex        String      @default("#9ca3af")
  quantity        Int
  actualQuantity  Int?
  fabricDefect    Int         @default(0)
  defectNote      String?
  status          String      @default("issued") // issued | in_work | pending_ironing | pending_qc | completed
  startedAt       DateTime?   // Когда взято в работу
  ironedAt        DateTime?   // Когда отглажено
  qcAt            DateTime?   // Когда прошло ОТК
  completedAt     DateTime?   // Когда завершено
  sewingTask      SewingTask  @relation(fields: [sewingTaskId], references: [id], onDelete: Cascade)
  product         Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  reworks         SewingRework[]
}

// ============ МОДУЛЬ 4: Распределение по городам (бывш. План селлеров) ============
model SellerPlan {
  id          String           @id @default(cuid())
  sellerName  String
  status      String           @default("draft") // draft | approved | distributed
  customerId  String?
  customer    Customer?        @relation(fields: [customerId], references: [id])
  items       SellerPlanItem[]
  boxes       Box[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

model SellerPlanItem {
  id           String            @id @default(cuid())
  sellerPlanId String
  productId    String
  size         String
  color        String
  colorHex     String            @default("#9ca3af")
  quantity     Int
  cities       SellerPlanCity[]
  sellerPlan   SellerPlan        @relation(fields: [sellerPlanId], references: [id], onDelete: Cascade)
  product      Product           @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model SellerPlanCity {
  id               String          @id @default(cuid())
  sellerPlanItemId String
  city             String
  quantity         Int
  sellerPlanItem   SellerPlanItem  @relation(fields: [sellerPlanItemId], references: [id], onDelete: Cascade)
}

// ============ МОДУЛЬ 5: Автоматическое распределение по коробам ============
model Box {
  id            String     @id @default(cuid())
  sellerPlanId  String
  boxNumber     Int
  city          String
  boxTypeId     String?    // Тип короба из справочника
  status        String     @default("forming") // forming | assembled | checked | shipped
  items         BoxItem[]
  sellerPlan    SellerPlan @relation(fields: [sellerPlanId], references: [id])
  boxType       BoxType?   @relation(fields: [boxTypeId], references: [id])
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
}

model BoxItem {
  id          String  @id @default(cuid())
  boxId       String
  productId   String
  size        String
  color       String
  colorHex    String  @default("#9ca3af")
  plannedQty  Int
  actualQty   Int?
  box         Box     @relation(fields: [boxId], references: [id], onDelete: Cascade)
  product     Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

// ============ МОДУЛЬ 6: Учёт материалов ============
// Категория типа материала: fabric (ткань) или furniture (фурнитура)
model MaterialType {
  id        String         @id @default(cuid())
  name      String         @unique
  category  String         @default("fabric") // "fabric" = ткань, "furniture" = фурнитура
  materials Material[]
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
}

model Material {
  id              String         @id @default(cuid())
  materialTypeId  String
  name            String
  totalQty        Float          @default(0)         // Кол-во в базовой единице
  baseUnit        String         @default("шт")      // Базовая единица: пм, кг, м, шт
  inputUnit       String         @default("шт")      // Единица поступления: пм, кг, упак, бобина, шт
  conversionRate  Float          @default(1)         // Коэфф. конвертации: базовых ед. в 1 ед. поступления
  ownershipType   String         @default("own")     // "own" = свой, "customer" = давальческий
  customerId      String?                             // заказчик для давальческого материала
  customer        Customer?      @relation(fields: [customerId], references: [id], onDelete: SetNull)
  entries         MaterialEntry[]
  norms           MaterialNorm[]
  materialType    MaterialType   @relation(fields: [materialTypeId], references: [id], onDelete: Cascade)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
}

model MaterialEntry {
  id              String     @id @default(cuid())
  materialId      String
  type            String     // incoming | consumed
  qty             Float      // Кол-во в базовой единице
  inputQty        Float      @default(0) // Кол-во в единице поступления (5 бобин, 3 упак)
  inputUnit       String?    // Единица поступления
  conversionRate  Float      @default(1) // Коэфф. конвертации на момент записи
  date            DateTime   @default(now())
  cuttingPlanId   String?
  note            String?
  material        Material   @relation(fields: [materialId], references: [id], onDelete: Cascade)
  createdAt       DateTime   @default(now())
}

model MaterialNorm {
  id                   String   @id @default(cuid())
  materialId           String
  productId            String
  consumptionPerUnit   Float
  unit                 String   @default("гр")
  autoCalculated       Boolean  @default(false)
  material             Material @relation(fields: [materialId], references: [id], onDelete: Cascade)
  product              Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([materialId, productId])
}

// ============ МОДУЛЬ 7: Счета (выставление) ============
model Invoice {
  id            String         @id @default(cuid())
  number        String         @unique  // Номер счета (авто или ручной)
  date          DateTime       @default(now())
  customerId    String
  customer      Customer       @relation(fields: [customerId], references: [id])
  planId        String?        // Привязка к плану пошива
  status        String         @default("draft") // draft | sent | paid | cancelled
  dueDate       DateTime?      // Срок оплаты
  note          String?        // Примечание
  items         InvoiceItem[]
  upds          UPD[]
  totalAmount   Float          @default(0)
  vatRate       Float          @default(20)  // Ставка НДС %
  vatAmount     Float          @default(0)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model InvoiceItem {
  id          String   @id @default(cuid())
  invoiceId   String
  productId   String?
  product     Product? @relation(fields: [productId], references: [id])
  description String   // Наименование позиции
  quantity    Int      @default(1)
  unit        String   @default("шт")
  price       Float    @default(0)  // Цена за единицу
  amount      Float    @default(0)  // Сумма = quantity * price
  vatRate     Float?   // Если отличается от ставки счёта
  vatAmount   Float?   // Сумма НДС позиции
  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
}

// ============ МОДУЛЬ 8: УПД (Универсальный передаточный документ) ============
model UPD {
  id            String     @id @default(cuid())
  number        String     @unique  // Номер УПД
  date          DateTime   @default(now())
  customerId    String
  customer      Customer   @relation(fields: [customerId], references: [id])
  invoiceId     String?    // Привязка к счёту
  invoice       Invoice?   @relation(fields: [invoiceId], references: [id])
  sellerPlanId  String?    // Привязка к отгрузке
  status        String     @default("draft") // draft | confirmed | sent | signed
  operationType String     @default("shipment") // shipment | transfer | return
  note          String?
  items         UPDItem[]
  totalAmount   Float      @default(0)
  vatRate       Float      @default(20)
  vatAmount     Float      @default(0)
  createdBy     String?    // Кто создал (id сотрудника)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
}

model UPDItem {
  id           String  @id @default(cuid())
  updId        String
  productId    String?
  product      Product? @relation(fields: [productId], references: [id])
  description  String  // Наименование товара
  quantity     Int     @default(1)
  unit         String  @default("шт")
  price        Float   @default(0)
  amount       Float   @default(0)
  vatRate      Float?
  vatAmount    Float?
  upd          UPD     @relation(fields: [updId], references: [id], onDelete: Cascade)
}

// ============ МОДУЛЬ 9: CRM — Сделки и переговоры ============
model Deal {
  id          String        @id @default(cuid())
  title       String        // Название сделки / тема переговоров
  customerId  String
  customer    Customer      @relation(fields: [customerId], references: [id])
  status      String        @default("new") // new | negotiation | agreed | won | lost | suspended
  amount      Float?        // Предполагаемая сумма
  description String?       // Описание / суть переговоров
  result      String?       // Итог переговоров
  nextStep    String?       // Следующий шаг
  deadline    DateTime?     // Срок сделки
  contacts    DealContact[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model DealContact {
  id          String   @id @default(cuid())
  dealId      String
  date        DateTime @default(now())
  type        String   @default("meeting") // meeting | call | email | note
  result      String?  // Результат встречи / звонка
  description String?  // Подробности
  nextStep    String?  // Что делать дальше
  deal        Deal     @relation(fields: [dealId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
}

// ============ МОДУЛЬ 10: Договоры ============
model Contract {
  id            String     @id @default(cuid())
  number        String     @unique  // Номер договора
  date          DateTime   @default(now())
  customerId    String
  customer      Customer   @relation(fields: [customerId], references: [id])
  type          String     @default("service") // service | supply
  // service = договор на услуги (пошив), supply = договор на поставку
  status        String     @default("draft") // draft | active | completed | terminated
  subject       String?    // Предмет договора
  amount        Float?     // Сумма договора
  vatRate       Float      @default(20)  // Ставка НДС %
  vatAmount     Float?     // Сумма НДС
  startDate     DateTime?  // Дата начала действия
  endDate       DateTime?  // Дата окончания
  paymentTerms  String?    // Условия оплаты
  deliveryTerms String?    // Условия поставки
  note          String?
  planId        String?    // Привязка к плану пошива
  invoiceId     String?    // Привязка к счёту
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
}